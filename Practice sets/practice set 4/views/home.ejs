<%- include('partials/head') %>
  </head>
  <body class="bg-black text-white">
    <%- include('partials/nav') %>

    <!-- Hero Section -->
    <section
      class="h-[80vh] w-full bg-cover bg-center flex items-end p-10"
      style="
        background-image: url('https://wallpaperaccess.com/full/329583.jpg');
      "
    >
      <div class="max-w-xl">
        <h2 class="text-5xl font-extrabold mb-4">Featured Movie</h2>
        <p class="text-gray-300 mb-4">
          A thrilling adventure of heroes rising against impossible odds.
        </p>
        <button
          class="bg-blue-600 px-6 py-2 rounded-lg text-lg font-semibold hover:bg-blue-700"
        >
          ▶ Watch Now
        </button>
      </div>
    </section>

    <!-- Trending Movies -->
    <section class="px-6 mt-10">
      <h2 class="text-2xl font-bold mb-4">Recent Uploads</h2>
      <div
        class="flex gap-3 overflow-x-auto whitespace-nowrap px-2 py-4 scroll-smooth modern-scroll"
      >
        <!-- Card 1 -->
         <% homeCard.forEach((card)=>{ %>
          <%- include("partials/card", { card }) %>
         <% }) %>


  <!-- Glassmorphism Info Bar -->

</div>


    </section>
  </body>
</html>
